# Database
DATABASE_URL=postgresql+asyncpg://ainote:ainote@db:5432/ainote_community

# JWT
JWT_SECRET=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# App
APP_BASE_URL=http://localhost:3000
OAUTH_ENCRYPTION_KEY=

# Synology Note Station pull-only sync
NSX_IMPORTS_PATH=./data/nsx_imports
NSX_IMAGES_PATH=./data/nsx_images
SYNOLOGY_URL=
SYNOLOGY_USER=
SYNOLOGY_PASSWORD=
SYNOLOGY_VERIFY_SSL=false

# Optional GitHub feedback bridge
GITHUB_FEEDBACK_REPO=
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_LABELS=community-feedback,ainote-community
